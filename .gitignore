# Compiled final ROM image for SNES
*.sfc

# Compiled object files and symbol maps used by the linker
*.obj
*.sym

# Debug files generated at various build and optimization stages (e.g. .ps.01.dbg, .opt.02.dbg)
*.dbg

# Raw graphic data generated by GFXCONV from PNG files (tiles and color palettes)
*.pic
*.pal

# Python cache from running utility scripts (like streamer.py, remove_it_channel.py)
__pycache__/
*.pyc
*.pyo

# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*